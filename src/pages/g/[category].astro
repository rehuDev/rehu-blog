---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  
  return [
    { params: { category: "Dev"}, props: {posts: allPosts} },	
    { params: { category: "Health" }, props: {posts: allPosts} },	
    { params: { category: "IT" }, props: {posts: allPosts} },	
  ];
}

const { category } = Astro.params;
const { posts } = Astro.props;

const filteredPosts = posts.filter((post) => 
  post.data.categories?.includes(category)
);
---

<BaseLayout title={`${category} 갤러리 - 레후 블로그`}>
  <p>Posts category is {category}</p>
  <ul>
    {filteredPosts.map((post) => (
      <li><a href={`/posts/${post.data.slug}`}>{post.data.title}</a></li>
    ))}
  </ul>
</BaseLayout>