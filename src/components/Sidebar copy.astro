---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 서버 단에서 미리 페이지 단위(7개씩)로 배열을 쪼개놓습니다.
const POSTS_PER_PAGE = 7;
const pagesChunks = [];

for (let i = 0; i < sortedPosts.length; i += POSTS_PER_PAGE) {
  pagesChunks.push(sortedPosts.slice(i, i + POSTS_PER_PAGE));
}
---

<div class="recent-posts-widget">
  <div class="widget-content">
    {pagesChunks.map((chunk, pageIndex) => {
      // 7개의 데이터를 다시 2개(이미지)와 5개(리스트)로 나눔
      const imagePosts = chunk.slice(0, 2);
      const listPosts = chunk.slice(2, 7);

      return (
        // 첫 번째 페이지(pageIndex === 0)만 'active' 클래스를 주어 보이게 함
        <div class={`page-group ${pageIndex === 0 ? 'active' : ''}`} data-page={pageIndex + 1}>
          
          <div class="image-posts-group">
            {imagePosts.map(post => (
              <a href={`/blog/${post.slug}`} class="image-card">
                <img src={post.data.image} alt={post.data.title} />
                <h4>{post.data.title}</h4>
              </a>
            ))}
          </div>

          <ul class="list-posts-group">
            {listPosts.map(post => (
              <li>
                <a href={`/blog/${post.slug}`}>{post.data.title}</a>
              </li>
            ))}
          </ul>
          
        </div>
      );
    })}
  </div>

  <div class="pagination-controls" data-total-pages={pagesChunks.length}>
    <button id="prev-btn" disabled>이전</button>
    <button id="next-btn">다음</button>
  </div>
</div>

<style>
  /* 기본적으로 모든 페이지 그룹을 숨김 */
  .page-group {
    display: none;
  }

  /* active 클래스가 붙은 그룹만 화면에 표시 */
  .page-group.active {
    display: block; 
    /* 페이드인 애니메이션 추가 가능 */
    animation: fadeIn 0.3s ease-in-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* 나머지 스타일 자유롭게 작성... */
</style>

<script>
  // 아주 가벼운 DOM 제어 스크립트
  const widget = document.querySelector('.recent-posts-widget');
  const pages = widget.querySelectorAll('.page-group');
  const prevBtn = widget.querySelector('#prev-btn');
  const nextBtn = widget.querySelector('#next-btn');
  
  const totalPages = parseInt(widget.querySelector('.pagination-controls').dataset.totalPages);
  let currentPage = 1;

  function updateView() {
    // 1. 모든 페이지 숨기기
    pages.forEach(page => page.classList.remove('active'));
    
    // 2. 현재 페이지 번호에 맞는 그룹만 보여주기 (인덱스는 0부터 시작하므로 -1)
    pages[currentPage - 1].classList.add('active');

    // 3. 버튼 활성/비활성 상태 변경
    prevBtn.disabled = currentPage === 1;
    nextBtn.disabled = currentPage === totalPages;
  }

  prevBtn.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      updateView();
    }
  });

  nextBtn.addEventListener('click', () => {
    if (currentPage < totalPages) {
      currentPage++;
      updateView();
    }
  });
</script>