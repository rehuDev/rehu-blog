---
import { getCollection } from "astro:content";
const allPosts = await getCollection("blog");
const postCount = allPosts.length;
const totalCharacters = allPosts.reduce((acc, post) => {
	const pureTextCount = post.body?.replace(/\s+/g, '').length ?? 0;
	return acc + pureTextCount;
}, 0);
---

<nav>
	<div class="nav-container">
		<ul>
			<li><a href="/g" title="갤러리 카테고리">갤러리</a></li>
			<li><a href="/m" title="마이너 카테고리">마이너갤</a></li>
			<li><a href="/mi" title="창작물 포트폴리오">미니갤</a></li>
			<li><a href="/pr" title="레후의 삶">인물갤</a></li>
		</ul>
		<div class="extra-info">
			<span class="ticker-item item-1">총 <span class="em">{postCount.toLocaleString()}개</span> 게시글 등록</span>
			<span class="ticker-item item-2">총 문자 <span class="em2">{totalCharacters.toLocaleString()}자</span> 작성</span>
		</div>
	</div>
</nav>

<style>
	nav {
		background-color: var(--dc-blue-3);
	}
	.nav-container {
		display: flex;
		align-items: center;
		height: clamp(34px, 3.8rem, 46px);
		max-width: var(--layout-max-width);
		margin: 0 auto;
		overflow: hidden;
	}

	nav ul {
		display: flex;
		justify-content: space-between;
		height: 100%;
		width: 100%;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	nav ul a {
		display: flex;
		align-items: center;
		height: 100%;
		padding: 0 10px;
		color: #fff;
		font-size: clamp(13px, 1.5rem, 18px);
		font-weight: 700;
		line-height: 1;
		letter-spacing: -1px;
		white-space: nowrap;
		text-decoration: none;
	}
	nav ul a:hover, 
	nav ul a:focus {
		color: #FFED44;
		text-decoration: underline;
	}

	.extra-info {
		display: none;
	}

	@media (min-width: 576px) {
		.nav-container {
			justify-content: space-between;
		}
		nav ul {
			max-width: clamp(250px, 32rem, 400px);
		}
		
		.extra-info {
			display: grid;
			align-items: center;
			text-align: end;
			padding: 0 10px;
			color: rgba(255, 255, 255, 0.7);
			font-size: clamp(12px, 1.5rem, 18px);
			white-space: nowrap;
		}
		.extra-info .em {
			color: #ffff99;
		}
		.extra-info .em2 {
			color: #ffbbee;
		}
		
		.ticker-item {
			grid-area: 1 / 1;
			animation: fadeTicker 10s infinite;
		}
		.ticker-item.item-1 {
			animation-delay: 0s;
		}
		.ticker-item.item-2 {
			animation-delay: -5s;
		}
		@keyframes fadeTicker {
			0%, 45% {
				opacity: 1;
				visibility: visible;
			}
			/* 45~50% 구간(0.5s) 동안 자연스럽게 페이드아웃 교체. 화면에서 숨겨 클릭 방지. */
			50%, 95% {
				opacity: 0;
				visibility: hidden;
			}
			100% {
				opacity: 1;
				visibility: visible;
			}
		}
	}

	@media (min-width: 768px) {
		.nav-container {
			height: clamp(36px, 4.2rem, 50px);
		}
	}
</style>