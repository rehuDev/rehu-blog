<div class="content-wrapper">
  <div class="left-ad-area">
    <img src="../../public/광고판 eg.png" width="100%" height="100%" />
  </div>
  <article>
    <slot />
  </article>
  <aside>

  </aside>
</div>

<style>
  .content-wrapper {
    display: grid;
    grid-template-columns: 1fr;
    max-width: 1300px;
    margin: 0 auto;
    width: 100%;
    flex: 1;
  }

  .left-ad-area {
    display: none;
  }
  aside {
    display: none;
  }

  article {
    padding: 1rem 0 1rem 1rem;
    margin: 0 .75rem 0 0;
    overflow: hidden;
  }


  @media (min-width: 768px) {
    .content-wrapper {
      grid-template-columns: 1fr calc(200px + .75rem);
    }
    
    aside {
      display: block;
      padding: .75rem .75rem .75rem 0;
    }

    article {
      border-width: 0 1px 0 1px;
      border-style: solid;
      border-color: #bbb;
    }
  }

  @media (min-width: 1000px) {
    .content-wrapper {
      grid-template-columns: 1fr calc(250px + .75rem);
    }
  }

  @media (min-width: 1700px) {
    .content-wrapper {
      grid-template-columns: auto 1fr calc(300px + .75rem);
    }

    .left-ad-area {
      display: block;
      float: left;
      width: 160px;
      margin: .75rem 0 0 -160px;
      position: sticky;
      top: .75rem;
      transform: translateX(-0.75rem);
    }
  }
</style>